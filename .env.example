# =============================================================================
# ShafJobs — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains your secrets!
# =============================================================================

# --- MongoDB -------------------------------------------------------------------
# Default: local MongoDB instance. Change if you're running Mongo on a different port.
MONGO_URI=mongodb://localhost:27017/shafjobs

# --- Adzuna -------------------------------------------------------------------
# Sign up at https://developer.adzuna.com (free tier: 250 calls/month)
# After signup, go to "My Apps" and copy your App ID and App Key.
ADZUNA_APP_ID=your_app_id_here
ADZUNA_APP_KEY=your_api_key_here

# --- The Muse -----------------------------------------------------------------
# Optional — works without a key (rate-limited) or with one (higher limits).
# Get a key at https://www.themuse.com/developers/api/v2
# Leave blank to use the public (no-key) endpoint.
MUSE_API_KEY=

# --- USAJobs ------------------------------------------------------------------
# Register for a key at https://developer.usajobs.gov/ApplyforKey
# USAJOBS_USER_AGENT must be your email address (used as the Authorization header).
USAJOBS_API_KEY=your_api_key_here
USAJOBS_USER_AGENT=your_email@example.com

# --- Remotive -----------------------------------------------------------------
# No key required. Leave as-is.
REMOTIVE_API_URL=https://remotive.io/api/remote-jobs

# --- Jobicy -------------------------------------------------------------------
# No key required. Leave as-is.
JOBICY_API_URL=https://jobicy.com/api/v2/remote-jobs

# --- Playwright / Scraping ----------------------------------------------------
# Delay range (milliseconds) between each page request in scrapers.
# Keeping these values randomizes the delay and reduces bot detection risk.
SCRAPE_DELAY_MIN_MS=1000
SCRAPE_DELAY_MAX_MS=3000

# How many hours to cache scraping results before re-scraping.
SCRAPE_CACHE_HOURS=6

# --- Server -------------------------------------------------------------------
PORT=3001
NODE_ENV=development
